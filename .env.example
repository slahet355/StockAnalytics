# Example environment variables
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stockanalytics
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/stockanalytics

REDIS_URL=redis://redis:6379/0

SECRET_KEY=replace-me

# Optional: Alpha Vantage API key for stock prices (get free key at alphavantage.co)
ALPHA_VANTAGE_KEY=demo
